APP_NAME="Financial Customer Support Agent"
APP_VERSION="0.1.0"
ENVIRONMENT="development"

CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

LLM_PROVIDER="gemini"
EMBEDDING_PROVIDER="gemini"
LLM_FALLBACK_PROVIDER=""
EMBEDDING_FALLBACK_PROVIDER=""

GEMINI_API_KEY="replace-with-your-api-key"
GEMINI_CHAT_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

GROQ_API_KEY=""
GROQ_CHAT_MODEL="llama-3.1-8b-instant"

DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres:5432/agent_db"
REDIS_URL="redis://redis:6379/0"

CHAT_PROMPT_VERSION="v1"
USER_ID_HASH_PEPPER="replace-with-a-random-pepper"

UNRESOLVED_SCORE_THRESHOLD="0.25"
UNRESOLVED_NEGATIVE_PHRASES="not enough information,i don't have enough information"

JWT_SECRET_KEY="replace-with-secure-random-secret-at-least-32-chars"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"
JWT_REFRESH_TOKEN_EXPIRE_DAYS="14"
JWT_ISSUER="ai-financial-support-platform"
JWT_AUDIENCE="ai-financial-support-platform-frontend"

RUN_DB_MIGRATIONS_ON_STARTUP="true"
CHAT_CACHE_TTL_SECONDS="300"
RATE_LIMIT_REQUESTS="10"
RATE_LIMIT_WINDOW_SECONDS="60"

SANITIZATION_MAX_LENGTH="4000"
SANITIZATION_BLOCK_PATTERNS="ignore previous instructions,system prompt,developer prompt,<script,drop table"
SANITIZATION_MASK_REPLACEMENT="[REDACTED]"

GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8000/auth/google/callback"
FRONTEND_OAUTH_SUCCESS_URL="http://localhost:5173/auth/callback"
DEFAULT_SSO_ROLE="agent"
